{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@theme-elements-effects/*": ["_active_theme/elements/effects/*"],
      "@theme-effects/*": ["_active_theme/effects/*"],
      "@override-elements-effects/*": ["../.artagents/elements/overrides/effects/*"],
      "@managed-elements-effects/*": ["../.artagents/elements/managed/effects/*"],
      "@pack-builtin-elements-effects/*": ["../artagents/packs/builtin/elements/effects/*"],
      "@theme-elements-animations/*": ["_active_theme/elements/animations/*"],
      "@theme-animations/*": ["_active_theme/animations/*"],
      "@override-elements-animations/*": ["../.artagents/elements/overrides/animations/*"],
      "@managed-elements-animations/*": ["../.artagents/elements/managed/animations/*"],
      "@pack-builtin-elements-animations/*": ["../artagents/packs/builtin/elements/animations/*"],
      "@theme-elements-transitions/*": ["_active_theme/elements/transitions/*"],
      "@theme-transitions/*": ["_active_theme/transitions/*"],
      "@override-elements-transitions/*": ["../.artagents/elements/overrides/transitions/*"],
      "@managed-elements-transitions/*": ["../.artagents/elements/managed/transitions/*"],
      "@pack-builtin-elements-transitions/*": ["../artagents/packs/builtin/elements/transitions/*"],
      "react": ["node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["node_modules/@types/react/jsx-runtime.d.ts"],
      "remotion": ["node_modules/remotion"]
    },
    "typeRoots": ["../node_modules/@types"],
    "lib": ["DOM", "ES2020"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src",
    "_active_theme/effects/**/*.{ts,tsx}",
    "_active_theme/elements/effects/**/*.{ts,tsx}",
    "_active_theme/animations/**/*.{ts,tsx}",
    "_active_theme/elements/animations/**/*.{ts,tsx}",
    "_active_theme/transitions/**/*.{ts,tsx}",
    "_active_theme/elements/transitions/**/*.{ts,tsx}",
    "../.artagents/elements/overrides/**/*.{ts,tsx}",
    "../.artagents/elements/managed/**/*.{ts,tsx}",
    "../artagents/packs/builtin/elements/**/*.{ts,tsx}",
    "../../themes/*/effects/**/*.{ts,tsx}",
    "../../themes/*/elements/effects/**/*.{ts,tsx}",
    "../../themes/*/animations/**/*.{ts,tsx}",
    "../../themes/*/elements/animations/**/*.{ts,tsx}",
    "../../themes/*/transitions/**/*.{ts,tsx}",
    "../../themes/*/elements/transitions/**/*.{ts,tsx}"
  ]
}
