{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Output schema for Seinfeld human review. Passed to builtin.human_review --response-schema.",
  "type": "object",
  "required": ["decisions", "completed_at"],
  "properties": {
    "decisions": {
      "type": "object",
      "description": "Per-clip review decisions keyed by clip id.",
      "additionalProperties": {
        "type": "object",
        "required": ["decision", "reject_reason", "edited_caption", "reviewed_at"],
        "properties": {
          "decision": {
            "type": "string",
            "description": "Accept or reject this clip.",
            "enum": ["accept", "reject"]
          },
          "reject_reason": {
            "description": "Reason for rejection, null if accepted.",
            "oneOf": [
              {"type": "null"},
              {
                "type": "string",
                "enum": ["watermark", "wrong_scene", "wrong_character", "bad_motion"]
              }
            ]
          },
          "edited_caption": {
            "description": "User-edited caption, null if unchanged.",
            "oneOf": [
              {"type": "null"},
              {"type": "string"}
            ]
          },
          "reviewed_at": {
            "type": "string",
            "description": "ISO 8601 timestamp when this clip was reviewed.",
            "format": "date-time"
          }
        }
      }
    },
    "completed_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when review was completed.",
      "format": "date-time"
    }
  }
}